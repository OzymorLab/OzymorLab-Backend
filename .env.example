# ── Database ──
DB_PASSWORD=aios_secret
DATABASE_URL=postgresql+asyncpg://aios:aios_secret@postgres:5432/aios
DATABASE_URL_SYNC=postgresql://aios:aios_secret@postgres:5432/aios

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── MinIO (S3-compatible storage) ──
MINIO_ENDPOINT=minio:9000
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123
MINIO_BUCKET=aios-submissions
MINIO_SECURE=false

# ── Google Gemini AI ──
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# ── Grading Defaults ──
GRADING_TEMPERATURE=0.0
GRADING_MAX_RETRIES=3

# ── Celery ──
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Grafana ──
GRAFANA_PASSWORD=admin

# ── App ──
APP_ENV=development
APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
