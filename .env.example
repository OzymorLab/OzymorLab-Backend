# ── Database ──
DB_PASSWORD=aios_secret
DATABASE_URL=postgresql+asyncpg://aios:aios_secret@postgres:5432/aios
DATABASE_URL_SYNC=postgresql://aios:aios_secret@postgres:5432/aios
DIRECT_URL=postgresql://aios:aios_secret@postgres:5432/aios

# ── Supabase Auth & Keys ──
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-publishable-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-for-symmetric-decoding

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── AWS S3 (Storage) ──
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=aios-submissions

# ── Google Gemini AI ──
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# ── Anthropic Claude AI ──
CLAUDE_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-opus-4-5

# ── OpenRouter (primary LLM provider — access any model via one key) ──
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── LLM Provider Strategy ──
# openrouter_primary → OpenRouter first, Gemini fallback  (recommended)
# claude_primary     → Claude first, Gemini fallback
# gemini_primary     → Gemini first, Claude fallback
# openrouter_only    → OpenRouter only, no fallback
# claude_only        → Claude only, no fallback
# gemini_only        → Gemini only, no fallback
LLM_PROVIDER_STRATEGY=openrouter_primary

# ── Grading Defaults ──
GRADING_TEMPERATURE=0.0
GRADING_MAX_RETRIES=3

# ── Celery ──
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Grafana ──
GRAFANA_PASSWORD=admin

# ── DEIS Diagram Evaluation Gateway ──
DEIS_API_URL=https://edaziadiagramv2.onrender.com
# For local development: DEIS_API_URL=http://localhost:8001


# ── App ──
APP_ENV=development
APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

